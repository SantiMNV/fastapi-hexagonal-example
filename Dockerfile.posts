FROM python:3.12-slim

WORKDIR /app

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV POST_SERVICE_EXTERNAL=false

COPY pyproject.toml README.md ./
COPY src ./src
COPY post_service_main.py ./

RUN pip install --no-cache-dir .

EXPOSE 8001

CMD ["uvicorn", "post_service_main:app", "--host", "0.0.0.0", "--port", "8001"]
