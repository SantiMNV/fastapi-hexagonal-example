APP_NAME=FastAPI Hexagonal Example
DATABASE_URL=sqlite:///./app.db
DB_ECHO=false

# Optional: split services — set peer base URL(s) and a shared secret for /internal/* calls.
# Leave unset for monolith (in-process gateways).
# USERS_SERVICE_URL=http://localhost:8000
# POSTS_SERVICE_URL=http://localhost:8001
# INTERNAL_API_KEY=
# INTERNAL_API_HEADER_NAME=X-Internal-Token
#
# Cross-context business rule: min account age before posting (0 = disabled in dev).
# MIN_ACCOUNT_AGE_BEFORE_POSTING_HOURS=24
